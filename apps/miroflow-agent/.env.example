# API for SearXNG Search (default - local, open-source, no API key needed)
# Ensure SearXNG is running locally (Docker port 8080)
# Run: docker run -d -p 8080:8080 --name searxng searxng/searxng:latest
SEARXNG_BASE_URL="http://127.0.0.1:8080"
SEARXNG_ENABLED="true"

# API for Crawl4AI Web Scraping (RECOMMENDED - local, open-source, no API key needed)
# Run: docker run -d -p 11235:11235 --name crawl4ai --shm-size=1g unclecode/crawl4ai:latest
CRAWL4AI_BASE_URL="http://127.0.0.1:11235"
CRAWL4AI_ENABLED="true"

# ZERO API KEY SETUP
# For fully local setup with no API keys, use agent config: mirothinker_1.7_microsandbox
# This uses: SearXNG (search) + Crawl4AI (scraping) + Microsandbox Docker (code execution)
# Required: docker pull microsandbox/python:latest
MICROSANDBOX_IMAGE="microsandbox/python:latest"
MICROSANDBOX_DOCKER_TIMEOUT="60"

# =============================================================================
# OPTIONAL: Alternative Services (not needed for zero-API-key setup)
# =============================================================================

# API for Google Search via Serper (optional - legacy, not needed with SearXNG)
# SERPER_API_KEY=your_serper_key
# SERPER_BASE_URL="https://google.serper.dev"

# API for Jina AI Web Scraping (optional - legacy, not needed with Crawl4AI)
# JINA_API_KEY=your_jina_key
# JINA_BASE_URL="https://r.jina.ai"

# API for E2B Sandbox (optional - cloud-based, requires API key from https://e2b.dev)
# Use agent config: mirothinker_1.7_crawl4ai or other configs with microsandbox-docker
E2B_API_KEY=your_e2b_key

# API for LLM-as-Judge (for benchmark evaluation)
OPENAI_API_KEY=your_openai_key
OPENAI_BASE_URL=https://api.openai.com/v1

# API for Open-Source Audio Transcription Tool (local Whisper-compatible model)
# Uses your local model at http://localhost:8001/v1
WHISPER_MODEL_NAME="qwen3.5"  # Your local model name
WHISPER_API_KEY="not-needed"  # Not required for local deployment
WHISPER_BASE_URL="http://localhost:8001/v1"

# API for Open-Source VQA Tool (local vision LLM)
# Uses your local vision-capable model at http://localhost:8001/v1
VISION_MODEL_NAME="qwen3.5"  # Your local model name
VISION_API_KEY="not-needed"  # Not required for local deployment
VISION_BASE_URL="http://localhost:8001/v1/chat/completions"

# API for Open-Source Reasoning Tool (local reasoning model)
# Uses your local reasoning model at http://localhost:8001/v1
REASONING_MODEL_NAME="qwen3.5"  # Your local model name
REASONING_API_KEY="not-needed"  # Not required for local deployment
REASONING_BASE_URL="http://localhost:8001/v1/chat/completions"

# API for Claude Sonnet 3.7 as Commercial Tools (optional)
ANTHROPIC_API_KEY=your_anthropic_key
ANTHROPIC_BASE_URL=https://api.anthropic.com

# API for Sogou Search (optional)
TENCENTCLOUD_SECRET_ID=your_tencent_cloud_secret_id
TENCENTCLOUD_SECRET_KEY=your_tencent_cloud_secret_key

# =============================================================================
# AUTHENTICATION (for multi-user access)
# =============================================================================

# Set to "false" to disable auth (dev mode, all tasks shared)
AUTH_ENABLED="true"

# Shared password that all users enter to access the app
SHARED_ACCESS_PASSWORD="changeme"

# Admin password — login with this grants admin role for dashboard access
ADMIN_PASSWORD="admin-changeme"

# Secret key for signing JWT tokens (change in production)
JWT_SECRET="mirothinker-dev-secret-change-in-production"